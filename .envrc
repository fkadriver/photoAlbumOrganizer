source venv/bin/activate

# On NixOS, Python C extensions (numpy, opencv, mediapipe) need libstdc++, libGL,
# and libxcb on LD_LIBRARY_PATH. After `nixos-rebuild switch` these are covered by
# nix-ld (daily-driver.nix), but the nix-build fallback below keeps things working
# in the meantime or on systems without that module.
if [[ -n "${NIX_LD_LIBRARY_PATH:-}" ]]; then
  export LD_LIBRARY_PATH="${NIX_LD_LIBRARY_PATH}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
elif command -v nix-build &>/dev/null; then
  _gcc_lib=$(nix-build '<nixpkgs>' -A stdenv.cc.cc.lib --no-out-link 2>/dev/null)
  _libgl=$(nix-build '<nixpkgs>' -A libGL --no-out-link 2>/dev/null)
  _glib=$(nix-build '<nixpkgs>' -A glib.out --no-out-link 2>/dev/null)
  _zlib=$(nix-build '<nixpkgs>' -A zlib --no-out-link 2>/dev/null)
  _libxcb=$(nix-build '<nixpkgs>' -A xorg.libxcb --no-out-link 2>/dev/null)
  export LD_LIBRARY_PATH="${_gcc_lib}/lib:${_libgl}/lib:${_glib}/lib:${_zlib}/lib:${_libxcb}/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi

echo ""
echo "Photo Album Organizer — usage: ./photo_organizer.py -i"
echo ""
